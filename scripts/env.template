# ============================================================
#  Archimedes — Environment Variables Template
#  Copy to /etc/archimedes/core.env and /etc/archimedes/net.env
#  and fill in the values for your deployment.
#
#  Usage in service files:
#    EnvironmentFile=/etc/archimedes/core.env
# ============================================================

# ── Core (.NET 8) ────────────────────────────────────────────
# Port Core listens on
ARCHIMEDES_PORT=5051

# Net service URL (must match PORT in net section)
ARCHIMEDES_NET_URL=http://localhost:5052

# LLM model path (run scripts/setup-model.ps1 or pwsh setup-model.ps1 to download)
# Default: ~/.local/share/Archimedes/models/llama3.2-3b.gguf
ARCHIMEDES_MODEL_PATH=/home/archimedes/.archimedes/models/llama3.2-3b.gguf

# GPU layers for LLM inference (0 = CPU only, -1 = all layers on GPU)
LLM_GPU_LAYERS=0

# Data directory for Archimedes internal storage
# (procedures, tools, dataset, traces, etc.)
ARCHIMEDES_DATA_PATH=/home/archimedes/.local/share/Archimedes

# Log retention (days)
ARCHIMEDES_LOGS_RETENTION_DAYS=7

# Max artifacts size on disk (GB)
ARCHIMEDES_ARTIFACTS_MAX_GB=10

# Minimum free disk space before alerts (MB)
ARCHIMEDES_MIN_FREE_MB=500

# Git repo root (for SelfGitManager commits)
# ARCHIMEDES_REPO_ROOT=/opt/archimedes

# ── Net (Node.js) ────────────────────────────────────────────
# Port Net service listens on
PORT=5052

# Core service URL
CORE_URL=http://localhost:5051

# Firebase / Firestore (for Firestore relay — Android remote access)
# Leave empty to disable Firestore relay (local polling only)
GOOGLE_APPLICATION_CREDENTIALS=/etc/archimedes/firebase-credentials.json
FIREBASE_PROJECT_ID=archimedes-c76c3

# Log level (debug | info | warn | error)
LOG_LEVEL=info

# ── Android OTA (Phase 32) ───────────────────────────────────
# ADB WiFi port (default 5555 — rarely needs changing)
# ADB_PORT=5555

# ── Notes ────────────────────────────────────────────────────
# 1. LLM model: run  sudo -u archimedes pwsh /opt/archimedes/scripts/setup-model.ps1
# 2. Firebase:  place service account JSON at GOOGLE_APPLICATION_CREDENTIALS path
# 3. ADB WiFi:  sudo apt install android-tools-adb
#               then pair once per phone (Developer Options → Wireless Debugging)
