# Archimedes Net – Environment Variables
# Copy this file to .env.local and fill in real values
# NEVER commit .env.local

# Firebase / Firestore / FCM (uses service account for FCM HTTP v1)
GOOGLE_APPLICATION_CREDENTIALS=
FIREBASE_PROJECT_ID=archimedes-c76c3

# Firestore mode: real | emulator | memory
# - real: use GOOGLE_APPLICATION_CREDENTIALS to connect to real Firestore
# - emulator: use FIRESTORE_EMULATOR_HOST (default localhost:8080)
# - memory: in-memory store (no Firebase)
# Default: real if GOOGLE_APPLICATION_CREDENTIALS is set, else memory
FIRESTORE_MODE=
FIRESTORE_EMULATOR_HOST=

# Server config
PORT=5052
CORE_URL=http://localhost:5051

# Logging
LOG_LEVEL=info
