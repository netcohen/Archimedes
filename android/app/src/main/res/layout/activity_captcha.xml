<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:gravity="center_horizontal">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Captcha Verification"
        android:textSize="24sp"
        android:textStyle="bold"
        android:layout_marginBottom="24dp"/>

    <ImageView
        android:id="@+id/ivCaptcha"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:minHeight="100dp"
        android:minWidth="200dp"
        android:background="#EEEEEE"
        android:layout_marginBottom="16dp"
        android:contentDescription="Captcha image"/>

    <TextView
        android:id="@+id/tvCaptchaStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Enter the code shown above"
        android:textSize="14sp"
        android:gravity="center"
        android:layout_marginBottom="16dp"/>

    <EditText
        android:id="@+id/etCaptchaSolution"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Enter captcha code"
        android:inputType="textCapCharacters"
        android:gravity="center"
        android:textSize="24sp"
        android:letterSpacing="0.3"
        android:layout_marginBottom="24dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <Button
            android:id="@+id/btnCancelCaptcha"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Cancel"
            android:layout_marginEnd="8dp"/>

        <Button
            android:id="@+id/btnSubmitCaptcha"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Verify"
            android:layout_marginStart="8dp"/>
    </LinearLayout>

</LinearLayout>
