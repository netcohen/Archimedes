# Enforce LF line endings for code files
* text=auto eol=lf

# Source code
*.cs text eol=lf
*.ts text eol=lf
*.js text eol=lf
*.kt text eol=lf
*.java text eol=lf
*.json text eol=lf
*.xml text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf

# Scripts
*.ps1 text eol=crlf
*.bat text eol=crlf
*.sh text eol=lf

# Config
*.csproj text eol=lf
*.sln text eol=lf
*.gradle text eol=lf
*.gradle.kts text eol=lf
*.properties text eol=lf

# Binary files (no conversion)
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.jar binary
*.apk binary
*.aab binary
*.keystore binary
